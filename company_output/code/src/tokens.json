{
  "colors": {
    "bg-primary": "#FFFFFF",
    "bg-surface": "#F8F9FA",
    "bg-error": "#FEE2E2",
    "text-main": "#111827",
    "text-muted": "#6B7280",
    "text-error": "#991B1B",
    "brand-primary": "#2563EB",
    "brand-hover": "#1D4ED8",
    "status-pending": "#D97706",
    "status-completed": "#059669"
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px"
  },
  "typography": {
    "family-body": "'Inter', sans-serif",
    "family-mono": "'JetBrains Mono', monospace",
    "size-base": "16px",
    "weight-bold": 600
  },
  "motion": {
    "transition-ease": "cubic-bezier(0.4, 0, 0.2, 1)",
    "duration-fast": "150ms"
  },
  "border": {
    "primary": "1px solid #2563EB",
    "input": "1px solid #D1D5DB"
