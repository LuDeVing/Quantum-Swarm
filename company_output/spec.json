{
  "project_name": "todo",
  "features": [
    "add <description> [--priority high|medium|low]  \u2014 add a new task",
    "list [--filter <priority>]  \u2014 list all tasks",
    "done <id>  \u2014 mark task as complete",
    "delete <id>  \u2014 delete a task",
    "clear  \u2014 remove all completed tasks"
  ],
  "requirements": [
    "Tasks saved to todo.json (stdlib only)",
    "Each task: id, description, priority, status (pending/done), created_at",
    "Show priority and status in list output",
    "Handle invalid IDs gracefully",
    "Auto-increment task IDs"
  ],
  "data_model": {
    "id": "int \u2014 auto-incremented",
    "created_at": "str \u2014 ISO timestamp",
    "description": "str \u2014 free text",
    "priority": "str \u2014 high|medium|low"
  },
  "commands": [
    "add <description> [--priority high|medium|low]",
    "list [--filter <priority>]",
    "done <id>",
    "delete <id>",
    "clear"
  ]
}